# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key-here   # secret key, NOT anon key

# ─── Supabase Storage bucket names ───────────────────────────────────────────
STORAGE_BUCKET_FACE=aina-face-photos
STORAGE_BUCKET_BODY=aina-body-photos
STORAGE_BUCKET_AVATAR=aina-avatars

# ─── GPU Worker ───────────────────────────────────────────────────────────────
# Internal URL — never exposed to frontend
WORKER_URL=http://gpu-worker-host:8002

# ─── Avatar generation ───────────────────────────────────────────────────────
# AVATAR_PROVIDER controls which service generates avatars.
# Supported values: vertex | gemini | fal | replicate
# To migrate: change AVATAR_PROVIDER and add the matching API key.
# Nothing else in the codebase needs to change.
AVATAR_PROVIDER=vertex

# Your GCP project ID — the string one, not the number
# Find it: GCP Console → header dropdown → copy the "ID" column value
VERTEX_PROJECT_ID=<your-project-id>

# Must be us-central1 — Gemini image generation is only available there
VERTEX_LOCATION=us-central1

# The full contents of your service account JSON key, as a string.
# Paste the entire JSON on one line, wrapped in single quotes.
# Single quotes prevent the shell from interpreting special characters inside.
GOOGLE_CREDENTIALS_JSON=<your-google-credentials>

# ─── Session cookie ──────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=aina_session
SESSION_COOKIE_MAX_AGE=86400          # 24 hours in seconds
SESSION_COOKIE_SECURE=false           # set false for local HTTP dev
SESSION_COOKIE_SAMESITE=lax           # set lax for local HTTP dev

# SESSION_COOKIE_SECURE=true         #for production 
# SESSION_COOKIE_SAMESITE=none       #for production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
LOG_LEVEL=INFO